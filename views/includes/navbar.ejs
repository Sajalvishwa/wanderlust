<nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top">
  <div class="container d-flex align-items-center position-relative">

    <!-- 🔥 Logo -->
    <a class="navbar-brand fw-bold text-danger fs-4 d-flex align-items-center" href="/listings">
      <i class="bi bi-compass-fill me-2 text-danger"></i>
      WanderLust
    </a>

    <!-- 📱 Mobile Search Icon -->
    <div class="d-lg-none ms-2">
      <button class="btn btn-light border rounded-pill px-2" id="searchToggleBtn">
        <i class="bi bi-search fs-5"></i>
      </button>
    </div>

    <!-- 📱 Mobile Login -->
    <div class="dropdown d-lg-none ms-2">

      <button class="btn btn-light border rounded-pill px-2"
              data-bs-toggle="dropdown">
        <i class="bi bi-person-circle fs-5"></i>
      </button>

      <ul class="dropdown-menu dropdown-menu-end shadow">

        <% if (!currUser) { %>
          <li><a class="dropdown-item" href="/signup">Sign up</a></li>
          <li><a class="dropdown-item" href="/login">Log in</a></li>

        <% } else { %>
          <li class="dropdown-item text-muted">
            👋 <%= currUser.username %>
          </li>

          <li><hr class="dropdown-divider"></li>

          <li>
            <a class="dropdown-item text-danger" href="/logout">
              Logout
            </a>
          </li>
        <% } %>

      </ul>
    </div>

    <!-- 🔍 DESKTOP SEARCH (same as before) -->
    <form class="d-none d-lg-flex mx-auto"
          action="/listings"
          method="GET">

      <div class="input-group shadow-sm rounded-pill overflow-hidden">

        <input type="text"
               name="q"
               class="form-control border-0 px-4"
               placeholder="Search destinations">

        <button class="btn btn-danger px-4" type="submit">
          Search
        </button>

      </div>

    </form>

    <!-- 👉 Desktop Right -->
    <div class="d-none d-lg-flex align-items-center gap-3">

      <a href="#" class="text-dark text-decoration-none fw-semibold">
        WanderLust your home
      </a>

      <div class="dropdown">
        <button class="btn btn-light border rounded-pill px-3 d-flex align-items-center"
                data-bs-toggle="dropdown">
          <i class="bi bi-list me-2"></i>
          <i class="bi bi-person-circle fs-5"></i>
        </button>

        <ul class="dropdown-menu dropdown-menu-end shadow">

          <% if (!currUser) { %>
            <li><a class="dropdown-item" href="/signup">Sign up</a></li>
            <li><a class="dropdown-item" href="/login">Log in</a></li>

          <% } else { %>
            <li class="dropdown-item text-muted">
              👋 <%= currUser.username %>
            </li>

            <li><hr class="dropdown-divider"></li>

            <li>
              <a class="dropdown-item text-danger" href="/logout">
                Logout
              </a>
            </li>
          <% } %>

        </ul>
      </div>

    </div>

    <!-- 📱 MOBILE SEARCH BAR (HIDDEN BY DEFAULT) -->
    <form id="mobileSearchForm"
          class="d-none position-absolute start-0 end-0 top-100 bg-white p-3 shadow"
          action="/listings"
          method="GET">

      <div class="input-group shadow-sm rounded-pill overflow-hidden">

        <input type="text"
               name="q"
               class="form-control border-0 px-4"
               placeholder="Search destinations">

        <button class="btn btn-danger px-4" type="submit">
          Search
        </button>

      </div>

    </form>

  </div>
</nav>

<!-- ⚡ JS -->
<script>
  const btn = document.getElementById("searchToggleBtn");
  const searchForm = document.getElementById("mobileSearchForm");

  btn.addEventListener("click", () => {
    searchForm.classList.toggle("d-none");
  });

  // click outside to close
  document.addEventListener("click", (e) => {
    if (!btn.contains(e.target) && !searchForm.contains(e.target)) {
      searchForm.classList.add("d-none");
    }
  });
</script>