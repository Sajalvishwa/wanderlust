<% layout("layouts/boilerplate") %> 

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold">All Listings</h2>

  <a href="/listings/new" class="btn btn-danger rounded-pill">
    + Create New Listing
  </a>
</div>

<% if (q) { %>
  <h5 class="text-muted mb-3">
    🔍 Search results for: "<%= q %>"
  </h5>
<% } %>

<% if (allListings.length === 0) { %>

  <div class="text-center mt-5">
    <h3 class="text-muted">😕 No listings found</h3>
    <a href="/listings" class="btn btn-danger mt-2">View All</a>
  </div>

<% } else { %>

  <div class="row">

    <% for(let listing of allListings){ %>

      <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm border-0">

          <img 
            src="<%= listing.image?.url || 'https://images.unsplash.com/photo-1501785888041-af3ef285b470' %>" 
            class="card-img-top"
            style="height:250px; object-fit:cover;"
          >

          <div class="card-body">

            <h5 class="card-title fw-semibold">
              <%= listing.title %>
            </h5>

            <p class="text-muted mb-1">
              <%= listing.location %>, <%= listing.country %>
            </p>

            <p class="fw-bold">
              ₹ <%= listing.price %>
              <span class="fw-normal text-muted">/ night</span>
            </p>

            <a href="/listings/<%= listing._id %>" class="stretched-link"></a>

          </div>
        </div>
      </div>

    <% } %>

  </div>

<% } %>