<% layout("layouts/boilerplate") %>

<div class="row justify-content-center mt-4">
  <div class="col-md-8">

    <!-- LISTING CARD -->
    <div class="card shadow-sm border-0">

      <!-- Title -->
      <h2 class="fw-bold mb-2 px-3 pt-3 text-dark">
        <%= listing.title %>
      </h2>

      <!-- IMAGE ✅ FIXED -->
      <img 
        src="<%= listing.image.url %>" 
        class="card-img-top"
        style="height:400px; object-fit:cover;"
      >

      <div class="card-body p-4">

        <!-- Owner -->
        <p class="text-muted">
          Hosted by <b><%= listing.owner?.username %></b>
        </p>

        <!-- Location -->
        <p class="text-muted mb-3">
          <%= listing.location %>, <%= listing.country %>
        </p>

        <!-- Price -->
        <h4 class="fw-bold text-danger mb-3">
          ₹ <%= listing.price.toLocaleString("en-IN") %> 
          <span class="text-muted fs-6 fw-normal">/ night</span>
        </h4>

        <hr>

        <!-- Description -->
        <p class="mt-3 text-dark">
          <%= listing.description %>
        </p>

        <hr>

        <!-- OWNER BUTTONS -->
        <% if (currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>

          <div class="d-flex gap-2 mt-4">

            <!-- Edit -->
            <a href="/listings/<%= listing._id %>/edit" 
               class="btn btn-outline-dark rounded-pill flex-fill">
              Edit
            </a>

            <!-- Delete -->
            <form action="/listings/<%= listing._id %>?_method=DELETE" 
                  method="POST" 
                  class="flex-fill">
              <button type="submit" 
                      class="btn btn-danger rounded-pill w-100">
                Delete
              </button>
            </form>

          </div>

        <% } %>

        <!-- Add Review -->
        <div class="mt-3">
          <a href="/listings/<%= listing._id %>/reviews/new" 
             class="btn btn-outline-primary rounded-pill w-100">
            ⭐ Add Review
          </a>
        </div>

        <!-- Back -->
        <div class="mt-3">
          <a href="/listings" class="text-decoration-none text-muted">
            ← Back to All Listings
          </a>
        </div>

      </div>
    </div>

    <!-- REVIEWS -->
    <div class="mt-5">

      <h4 class="fw-bold mb-3 text-dark">⭐ Reviews</h4>

      <% if (listing.reviews.length === 0) { %>
        <p class="text-muted">No reviews yet.</p>
      <% } %>

      <% listing.reviews.forEach(review => { %>

        <div class="card mb-3 shadow-sm border-0 bg-light">
          <div class="card-body text-dark">

            <h6 class="fw-bold mb-1">
              <%= review.name || "Anonymous" %>
            </h6>

            <!-- Stars -->
            <p class="text-warning mb-1 fs-5">
              <% for(let i=0; i<review.rating; i++) { %> ★ <% } %>
              <% for(let i=review.rating; i<5; i++) { %> ☆ <% } %>
            </p>

            <p class="mb-2">
              <%= review.comment %>
            </p>

            <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" 
                  method="POST">
              <button class="btn btn-sm btn-outline-danger rounded-pill px-3">
                🗑 Delete
              </button>
            </form>

          </div>
        </div>

      <% }) %>

    </div>

  </div>
</div>