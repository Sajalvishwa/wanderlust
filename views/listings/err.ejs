<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Error</title>

    <style>
        body{
            font-family: Arial, sans-serif;
            background-color: #f8f9fa;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .error-container{
            background: white;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            text-align: center;
            width: 400px;
        }

        h1{
            color: #e63946;
        }

        p{
            margin-top: 10px;
            font-size: 18px;
        }

        a{
            display: inline-block;
            margin-top: 20px;
            text-decoration: none;
            background: #0077ff;
            color: white;
            padding: 10px 20px;
            border-radius: 5px;
        }

        a:hover{
            background: #0056cc;
        }
    </style>

</head>

<body>

<div class="error-container">

    <h1>Error <%= err.statusCode %></h1>

    <p><%= err.message %></p>

    <a href="/listings">Go Back</a>

</div>

</body>
</html>